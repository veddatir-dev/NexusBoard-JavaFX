<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="850.0" prefWidth="1400.0" styleClass="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.nexus.controller.FXMLDocumentController">

   <!-- Top Tab Selector & Global Actions -->
   <top>
      <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="toolbar" BorderPane.alignment="CENTER">
         <children>
            <Button fx:id="TabWhiteboardBtn" mnemonicParsing="false" onAction="#handleTabSwitch" styleClass="modern-button" text="🎨 Whiteboard" />
            <Button fx:id="TabCodeBtn" mnemonicParsing="false" onAction="#handleTabSwitch" styleClass="modern-button" text="💻 Code Editor" />
            <Button fx:id="TabDocBtn" mnemonicParsing="false" onAction="#handleTabSwitch" styleClass="modern-button" text="📄 Document" />
            <Region HBox.hgrow="ALWAYS" />
            <!-- Toggle Theme Button -->
            <ToggleButton fx:id="ThemeToggleBtn" mnemonicParsing="false" onAction="#handleThemeToggle" styleClass="modern-button" text="🌙 Dark Mode" />
            <Button fx:id="SaveProjectBtn" mnemonicParsing="false" onAction="#handleSaveProject" styleClass="modern-button" text="💾 Save" />
            <Button fx:id="LoadProjectBtn" mnemonicParsing="false" onAction="#handleLoadProject" styleClass="modern-button" text="📂 Open" />
            <Button fx:id="ExportBtn" mnemonicParsing="false" onAction="#handleExport" styleClass="modern-button" text="📤 Export" />
         </children>
         <padding>
            <Insets bottom="10.0" left="15.0" right="15.0" top="10.0" />
         </padding>
      </HBox>
   </top>

   <!-- Left Sidebar: 60px Drawing Tools Palette -->
   <left>
      <VBox alignment="TOP_CENTER" styleClass="sidebar" spacing="15.0" minWidth="60.0" prefWidth="60.0" maxWidth="60.0" BorderPane.alignment="CENTER">
         <children>
            <Button fx:id="SelectionBtn" mnemonicParsing="false" onAction="#handleSelectionTool" styleClass="tool-button" text="👆">
               <tooltip><Tooltip text="Select" /></tooltip>
            </Button>
            <Button fx:id="FreehandBtn" mnemonicParsing="false" onAction="#handleFreehandTool" styleClass="tool-button" text="✏">
               <tooltip><Tooltip text="Draw" /></tooltip>
            </Button>
            <Button fx:id="LineBtn" mnemonicParsing="false" onAction="#handleLineTool" styleClass="tool-button" text="➖">
               <tooltip><Tooltip text="Line / Connector" /></tooltip>
            </Button>
            <Button fx:id="TextBtn" mnemonicParsing="false" onAction="#handleTextTool" styleClass="tool-button" text="T">
               <tooltip><Tooltip text="Text" /></tooltip>
            </Button>
            <Button fx:id="EraserBtn" mnemonicParsing="false" onAction="#handleEraserTool" styleClass="tool-button" text="🧹">
               <tooltip><Tooltip text="Eraser" /></tooltip>
            </Button>
            <Separator />
            <Label text="Shapes" textFill="#00d4ff" style="-fx-font-size: 10px;"/>
            <ComboBox fx:id="ShapeSelector" promptText="⭕" styleClass="tool-button" maxWidth="50.0" />
            <Separator />
            <Label text="UML" textFill="#00d4ff" style="-fx-font-size: 10px;"/>
            <!-- Drag-and-drop palette buttons -->
            <Button fx:id="PaletteClassBtn" mnemonicParsing="false" styleClass="tool-button" text="📄">
               <tooltip><Tooltip text="UML Class" /></tooltip>
            </Button>
            <Button fx:id="PaletteDecisionBtn" mnemonicParsing="false" styleClass="tool-button" text="💠">
               <tooltip><Tooltip text="Decision" /></tooltip>
            </Button>
            <Button fx:id="PaletteActorBtn" mnemonicParsing="false" styleClass="tool-button" text="🧍">
               <tooltip><Tooltip text="Actor" /></tooltip>
            </Button>
         </children>
         <padding>
            <Insets bottom="10.0" left="5.0" right="5.0" top="10.0" />
         </padding>
      </VBox>
   </left>

   <!-- Center: Canvas with Side Panels -->
   <center>
      <SplitPane dividerPositions="0.8" styleClass="main-split-pane">
         <items>
            <!-- Main Content Area with StackPane for Tabs wrapped in ScrollPane -->
            <ScrollPane fitToHeight="true" fitToWidth="true" styleClass="canvas-scroll-pane">
                <content>
                    <StackPane fx:id="TabStackPane" styleClass="canvas-container" minWidth="1200" minHeight="800">
                       <children>
                          <!-- Whiteboard Tab -->
                          <AnchorPane fx:id="WhiteboardTab">
                             <children>
                                <Canvas fx:id="CanvasBox" onMousePressed="#startDrag" onMouseDragged="#whileDragging" onMouseReleased="#endDrag" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" />
                                <Canvas fx:id="GhostCanvas" mouseTransparent="true" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" />
                             </children>
                          </AnchorPane>
                          
                          <!-- Code Editor Tab -->
                          <TextArea fx:id="CodeEditorTab" styleClass="modern-text-area" visible="false" />
                          
                          <!-- Document Editor Tab -->
                          <TextArea fx:id="DocEditorTab" styleClass="modern-text-area" visible="false" />
                       </children>
                       <padding>
                          <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                       </padding>
                    </StackPane>
                </content>
            </ScrollPane>

            <!-- Right Sidebar: Properties, Layers, Network -->
            <ScrollPane fitToWidth="true" styleClass="right-sidebar-scroll">
               <content>
                <VBox styleClass="sidebar" spacing="10.0" minWidth="240.0">
                   <children>
                      <!-- Styling Section -->
                      <TitledPane animated="false" text="Style" textFill="#00d4ff">
                          <content>
                              <VBox spacing="5.0">
                                  <HBox spacing="10.0">
                                      <VBox>
                                          <Label styleClass="control-label" text="Stroke" />
                                          <ColorPicker fx:id="ColorBox" styleClass="modern-color-picker" />
                                      </VBox>
                                      <VBox>
                                          <Label styleClass="control-label" text="Fill" />
                                          <ColorPicker fx:id="FillColorBox" styleClass="modern-color-picker" />
                                      </VBox>
                                  </HBox>
                                  <Label styleClass="control-label" text="Stroke Width:" />
                                  <Slider fx:id="StrokeSizeSlider" max="20.0" min="1.0" value="2.0" styleClass="modern-slider" />
                              </VBox>
                          </content>
                      </TitledPane>

                      <!-- Transform Section -->
                      <TitledPane animated="false" text="Transform" textFill="#00d4ff">
                          <content>
                              <VBox spacing="5.0">
                                  <Label styleClass="control-label" text="Scale:" />
                                  <Slider fx:id="ScaleSlider" max="5.0" min="0.1" value="1.0" styleClass="modern-slider" />
                                  <Label styleClass="control-label" text="Rotation:" />
                                  <Slider fx:id="RotationSlider" max="360.0" min="0.0" value="0.0" styleClass="modern-slider" />
                                  <Label styleClass="control-label" text="Translate X:" />
                                  <Slider fx:id="TranslateXSlider" max="500.0" min="-500.0" value="0.0" styleClass="modern-slider" />
                                  <Label styleClass="control-label" text="Translate Y:" />
                                  <Slider fx:id="TranslateYSlider" max="500.0" min="-500.0" value="0.0" styleClass="modern-slider" />
                              </VBox>
                          </content>
                      </TitledPane>

                      <!-- Layers Section -->
                      <TitledPane animated="false" text="Layers" textFill="#00d4ff">
                         <content>
                            <VBox spacing="5.0">
                               <children>
                                  <ListView fx:id="LayerList" prefHeight="120.0" styleClass="shape-list" />
                                  <HBox spacing="5.0">
                                     <children>
                                        <Button fx:id="AddLayerBtn" mnemonicParsing="false" onAction="#handleAddLayer" styleClass="sidebar-button" text="+" HBox.hgrow="ALWAYS" />
                                        <Button fx:id="DeleteLayerBtn" mnemonicParsing="false" onAction="#handleDeleteLayer" styleClass="sidebar-button" text="-" HBox.hgrow="ALWAYS" />
                                        <Button fx:id="LayerUpBtn" mnemonicParsing="false" onAction="#handleLayerUp" styleClass="sidebar-button" text="↑" HBox.hgrow="ALWAYS" />
                                        <Button fx:id="LayerDownBtn" mnemonicParsing="false" onAction="#handleLayerDown" styleClass="sidebar-button" text="↓" HBox.hgrow="ALWAYS" />
                                     </children>
                                  </HBox>
                               </children>
                            </VBox>
                         </content>
                      </TitledPane>

                      <!-- Network Section -->
                      <TitledPane animated="false" text="Network" textFill="#00d4ff">
                          <content>
                              <VBox spacing="5.0">
                                  <Label styleClass="control-label" text="Network IP:" />
                                  <TextField fx:id="IPField" promptText="IP Address" styleClass="modern-text-field" />
                                  <Label styleClass="control-label" text="Port:" />
                                  <TextField fx:id="PortField" promptText="5000" text="5000" styleClass="modern-text-field" />
                                  <HBox spacing="5.0">
                                      <Button fx:id="HostBtn" mnemonicParsing="false" onAction="#handleHost" styleClass="sidebar-button" text="Host" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                                      <Button fx:id="ConnectBtn" mnemonicParsing="false" onAction="#handleConnect" styleClass="sidebar-button" text="Connect" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                                  </HBox>
                              </VBox>
                          </content>
                      </TitledPane>

                      <!-- Actions -->
                      <TitledPane animated="false" text="Actions" textFill="#00d4ff">
                          <content>
                              <VBox spacing="5.0">
                                  <Button fx:id="AIBtn" mnemonicParsing="false" onAction="#handleAIEnhance" styleClass="sidebar-button" text="🎨 AI Enhance" maxWidth="Infinity"/>
                                  <Button fx:id="ClearBtn" mnemonicParsing="false" onAction="#handleClear" styleClass="sidebar-button" text="🗑 Clear Canvas" maxWidth="Infinity" />
                              </VBox>
                          </content>
                      </TitledPane>

                   </children>
                   <padding>
                      <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                   </padding>
                </VBox>
               </content>
            </ScrollPane>
         </items>
      </SplitPane>
   </center>

   <!-- Bottom Status Bar -->
   <bottom>
      <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="status-bar">
         <children>
            <Label fx:id="StatusLabel" styleClass="status-text" text="Ready - Nexus Board v3.0 Professional" HBox.hgrow="ALWAYS" />
            <Label styleClass="status-info" text="Zoom: 100%" />
            <Label styleClass="status-info" text="Layers: 1" />
         </children>
         <padding>
            <Insets bottom="8.0" left="15.0" right="15.0" top="8.0" />
         </padding>
      </HBox>
   </bottom>

</BorderPane>
